# ── Frontend environment variables ────────────────────────────────────────────
# Copy this to .env and fill in values for local development.
#
# LOCAL DEV (npm run dev):
#   Point directly at the Spring Boot server running on your machine.
VITE_API_BASE_URL=http://localhost:8080/api/v1
#
# DOCKER (docker compose up --build):
#   Do NOT create a .env file — the Dockerfile sets VITE_API_BASE_URL=/api/v1
#   at build time via a build arg. Nginx proxies /api/ → backend:8080 internally.
