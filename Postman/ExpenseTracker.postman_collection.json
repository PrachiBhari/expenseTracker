          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Summary — This Month",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/summary?from=2026-06-01&to=2026-06-30",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "summary"],
              "query": [
                { "key": "from", "value": "2026-06-01" },
                { "key": "to", "value": "2026-06-30" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has totalIncome', () => pm.expect(json.totalIncome).to.be.a('number'));",
                  "pm.test('Has totalExpense', () => pm.expect(json.totalExpense).to.be.a('number'));",
                  "pm.test('netBalance = income - expense', () => {",
                  "  pm.expect(json.netBalance).to.equal(json.totalIncome - json.totalExpense);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Summary — Current Month (default)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/analytics/summary", "host": ["{{baseUrl}}"], "path": ["analytics", "summary"] }
          }
        },
        {
          "name": "Category Breakdown — Expenses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/by-category?type=EXPENSE&from=2026-06-01&to=2026-06-30",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "by-category"],
              "query": [
                { "key": "type", "value": "EXPENSE" },
                { "key": "from", "value": "2026-06-01" },
                { "key": "to", "value": "2026-06-30" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('Sorted by total desc', () => {",
                  "  const arr = pm.response.json();",
                  "  for (let i = 0; i < arr.length - 1; i++) {",
                  "    pm.expect(arr[i].total).to.be.at.least(arr[i+1].total);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Category Breakdown — Incomes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/by-category?type=INCOME",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "by-category"],
              "query": [{ "key": "type", "value": "INCOME" }]
            }
          }
        },
        {
          "name": "Trends — Last 6 Months",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/trends?months=6",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "trends"],
              "query": [{ "key": "months", "value": "6" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns 6 months', () => pm.expect(pm.response.json()).to.have.lengthOf(6));",
                  "pm.test('Each point has month, income, expense', () => {",
                  "  pm.response.json().forEach(pt => {",
                  "    pm.expect(pt).to.have.property('month');",
                  "    pm.expect(pt).to.have.property('income');",
                  "    pm.expect(pt).to.have.property('expense');",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Trends — Last 3 Months",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/analytics/trends?months=3",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "trends"],
              "query": [{ "key": "months", "value": "3" }]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/actuator/health", "host": ["{{baseUrl}}"], "path": ["actuator", "health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status UP', () => pm.expect(pm.response.json().status).to.equal('UP'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
