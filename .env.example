# =============================================================================
# .env.example — Committed to source control as a template.
# Copy this to .env (which IS in .gitignore) and fill in real values.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with real values
#   docker compose up --build
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=fintrack
DB_USERNAME=fintrack
DB_PASSWORD=change_this_to_a_secure_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-256-bits

# Access token lives 15 minutes (900,000 ms)
JWT_ACCESS_EXPIRATION=900000

# Refresh token lives 7 days (604,800,000 ms)
JWT_REFRESH_EXPIRATION=604800000

# ── Spring ────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── CORS ─────────────────────────────────────────────────────────────────────
# In production: replace with your actual frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80
